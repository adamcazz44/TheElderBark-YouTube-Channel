{
  "name": "the-elder-bark",
  "version": "1.0.0",
  "private": true,
  "description": "The Elder Bark — AI-automated senior-dog comedy YouTube Shorts channel: senior-dog footage + meme-style captions + royalty-free music, rendered to vertical MP4 via Remotion.",
  "scripts": {
    "test:render": "npm --prefix remotion/short-renderer run render",
    "fetch:footage": "node scripts/fetch-footage.js",
    "generate:quotes": "node scripts/generate-quotes.js",
    "render:video": "node scripts/render-video.js",
    "generate:thumbnail": "node scripts/generate-thumbnail.js",
    "produce": "node scripts/produce-video.js",
    "auth:youtube": "node scripts/auth-youtube.js",
    "upload:youtube": "node scripts/upload-youtube.js",
    "publish": "node scripts/publish-video.js",
    "reject": "node scripts/reject-video.js",
    "pipeline": "node scripts/pipeline.js",
    "cron:daily": "node scripts/cron-daily.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "axios": "^1.7.0",
    "canvas": "^3.2.3",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "googleapis": "^173.0.0",
    "open": "^8.4.2",
    "sharp": "^0.35.1"
  }
